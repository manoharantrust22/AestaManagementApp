# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (required for admin operations like creating users)
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Feature flags
# Redesigned All Site Expenses page (Labor / Building groups, single scrollbar,
# sticky filter bar). Off by default. Set to "true" to enable.
NEXT_PUBLIC_FF_EXPENSES_REDESIGN=false
